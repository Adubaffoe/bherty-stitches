rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Product images — admin can upload; anyone can read
    match /products/{filename} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'DBlOD4Xr4Xc59ZHmhtNNsUbNu9p2';
    }

    // Block all other paths
    match /{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == 'DBlOD4Xr4Xc59ZHmhtNNsUbNu9p2';
    }
  }
}
